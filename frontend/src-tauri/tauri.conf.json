{
  "package": {
    "productName": "AgendaApp",
    "version": "0.1.0"
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "dist"
  },
  "tauri": {
    "bundle": {
      "identifier": "com.agendaapp.desktop",
      "icon": ["icons/32x32.png"]
    },
    "allowlist": {
      "http": {
        "all": true
      }
    },
    "windows": [
      {
        "title": "AgendaApp",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ]
  }
}
